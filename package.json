{
	"name": "dhtml",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts",
		"./server": "./src/server.ts"
	},
	"scripts": {
		"build": "node scripts/build/main.ts",
		"build:watch": "node --watch scripts/build/main.ts --watch",
		"format": "prettier --write . --cache",
		"check": "tsc",
		"test": "node scripts/test/main.ts 'src/{client,server}/tests/*.test.ts'",
		"test:prod": "pnpm run test -- --prod",
		"bench": "node scripts/test/main.ts --prod --bench 'src/{client,server}/tests/bench.ts'"
	},
	"devDependencies": {
		"@types/node": "^25.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"typescript": "catalog:"
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-organize-imports"
		],
		"arrowParens": "avoid",
		"printWidth": 120,
		"semi": false,
		"singleQuote": true,
		"trailingComma": "all",
		"useTabs": true
	},
	"packageManager": "pnpm@11.0.3+sha512.10448f2988933787c6699aef683174c741f6472ad91b7e3c8fe3e2bda57be8a0f7caf58949b8bc22e624578b3dc6e57876ba4c631928a1b84cc141e12c79bccd"
}
